DirectoryIndex index.html
Options -MultiViews -Indexes

# ─── MIME types Vite may produce ──────────────────────────────────────
AddType application/javascript .js .mjs
AddType text/css .css

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── 1. HTTPS redirect (enable when Apache terminates TLS) ──────────
  # RewriteCond %{HTTPS} !=on
  # RewriteCond %{HTTP_HOST} !^localhost$ [NC]
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ── 2. Real files — serve directly, stop rewriting ─────────────────
  #    This MUST come first so /assets/*.js, /assets/*.css, images,
  #    fonts, sitemap.xml, robots.txt etc. are never rewritten.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # ── 3. Well-known / API passthrough ────────────────────────────────
  RewriteCond %{REQUEST_URI} ^/\.well-known/ [OR]
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^ - [L]

  # ── 4. Prerendered directory — serve its index.html directly ───────
  #    e.g. /tools/pdf-editor  →  /tools/pdf-editor/index.html
  #    Only fires when no real file matched above AND a prerendered
  #    index.html exists inside that path's directory.
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.+)$ $1/index.html [L]

  # ── 5. SPA fallback — everything else goes to root index.html ──────
  #    React Router handles client-side routing from here.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Cache control ────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed Vite assets — immutable for 1 year
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript       "access plus 1 year"
  ExpiresByType text/css              "access plus 1 year"
  # Images & fonts — 1 year (fingerprinted by Vite or versioned via ?v=)
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/gif             "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType font/woff             "access plus 1 year"
  ExpiresByType font/woff2            "access plus 1 year"
  # HTML — never cache (gets new asset hashes each build)
  ExpiresByType text/html             "access plus 0 seconds"
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Security & caching headers ──────────────────────────────────────
<IfModule mod_headers.c>
  # Security headers on every response
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Enable HSTS only after HTTPS is confirmed to work correctly.
  # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Vite hashed assets under /assets/ — immutable long cache
  <If "%{REQUEST_URI} =~ m#^/assets/#">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </If>

  # Static files outside /assets/ — moderate cache
  <FilesMatch "\.(css|js|mjs|png|jpg|jpeg|gif|svg|webp|woff|woff2)$">
    Header set Cache-Control "max-age=604800, public" "expr=%{REQUEST_URI} !~ m#^/assets/#"
  </FilesMatch>

  # HTML — must revalidate every time (picks up new asset hashes)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>